<fluent:RibbonWindow x:Class="DHBIMWATER.UI.Sandbox.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:fluent="urn:fluent-ribbon"
                     xmlns:local="clr-namespace:DHBIMWATER.UI.Sandbox"
                     d:DataContext="{d:DesignInstance Type=local:MainViewModel, IsDesignTimeCreatable=False}"
                     mc:Ignorable="d"
                     Title="DHBIMWATER"
                     Height="800" Width="1400"
                     WindowStartupLocation="CenterScreen"
                     WindowStyle="ThreeDBorderWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <fluent:Ribbon CanMinimize="False"
                       IsQuickAccessToolBarVisible="False"
                       Background="#004442"
                       BorderBrush="Gray"
                       BorderThickness="1">
            <fluent:RibbonTabItem Header="DHBIMWATER">
                <fluent:RibbonGroupBox Header="모델링">
                    <fluent:Button Header="모델링1"
                                   FontWeight="Normal"
                                   Command="{Binding OpenModeling1ViewCommand}"
                                   LargeIcon="pack://application:,,,/DHBIMWATER.UI;component/Resources/Icons/modeling.png"/>
                    <fluent:Button Header="모델링2"
                                   FontWeight="Normal"
                                   LargeIcon="pack://application:,,,/DHBIMWATER.UI;component/Resources/Icons/revit.png"
                                   Command="{Binding OpenGuideLineViewCommand}"/>
                    <fluent:Button Header="모델링3"        
                                   FontWeight="Normal"/>
                </fluent:RibbonGroupBox>
                
                <fluent:RibbonGroupBox Header="수량산출">
                    <fluent:Button Header="수량산출1"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="수량산출2"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="수량산출3"   
                                   FontWeight="Normal"/>
                </fluent:RibbonGroupBox>
                
                <fluent:RibbonGroupBox Header="도면화">
                    <fluent:Button Header="도면화1"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="도면화2"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="도면화3"
                                   FontWeight="Normal"/>
                </fluent:RibbonGroupBox>
                
                <fluent:RibbonGroupBox Header="유틸리티">
                    <fluent:Button Header="유틸리티1"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="유틸리티2"
                                   FontWeight="Normal"/>
                    <fluent:Button Header="유틸리티3"
                                   FontWeight="Normal"/>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>

        </fluent:Ribbon>
    </Grid>
</fluent:RibbonWindow>
