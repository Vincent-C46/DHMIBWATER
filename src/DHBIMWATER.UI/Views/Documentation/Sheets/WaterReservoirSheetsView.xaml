<Window x:Class="DHBIMWATER.UI.Views.Documentation.Sheets.WaterReservoirSheetsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:behaviors="clr-namespace:DHBIMWATER.UI.Behaviors"
        behaviors:DialogResultBehavior.DialogResult="{Binding SheetsDialogResult}"
        mc:Ignorable="d"
        Title="배수지 Sheets"
        Height="250" Width="200"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9"
        AllowsTransparency="False"
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <!-- Top: Buttons -->
        <Grid Grid.Row="1" Margin="12,10,12,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>           

            <Grid Grid.Row="0" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Sheets 시작 번호" Margin="0,5,0,5"
                               Foreground="{Binding TextBlock}"/>
                    <TextBox   Width="175" Height="35" Margin="0,0,0,10"
                               Text="{Binding SheetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Style="{StaticResource PrimaryTextBoxStyle}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Sheets 총 개수"
                               Margin="0,5,0,5"
                               Foreground="{Binding TextBlock}"/>
                    <TextBox  Width="175" Height="35" Margin="0,0,0,10"
                              Text="{Binding SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource PrimaryTextBoxStyle}"/>
                </StackPanel>
            </Grid>



            <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="OK"
                        Width="80" FontSize="15" Margin="0,0"
                        Style="{StaticResource PrimaryButtonStyle}"                        
                        Command="{Binding SheetsConfirmCommand}"
                        IsDefault="True"/>

                <Button Grid.Column="1" Content="Cancel"
                        Width="80" FontSize="15" Margin="5,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}"                        
                        Command="{Binding SheetsCancelCommand}"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
