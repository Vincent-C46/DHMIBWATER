<Window x:Class="DHBIMWATER.UI.Views.Documentation.Sheets.SheetManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:behaviors="clr-namespace:DHBIMWATER.UI.Behaviors"
        behaviors:DialogResultBehavior.DialogResult="{Binding DialogResult}"
        mc:Ignorable="d"
        Title="Sheets Manager"
        Height="500" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9"
        AllowsTransparency="False"
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"
                           Margin="0,0,0,0"/>

        <!-- Top: Buttons -->
        <Grid Grid.Row="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Add" Width="90" FontSize="15"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddCommand}"/>

                <Button Grid.Column="1" Content="Remove" Width="90" FontSize="15"
                        Command="{Binding RemoveCommand}" Margin="5,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="2" Content="Copy" Width="90" FontSize="15"
                        Command="{Binding CopyCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            <!-- 
            <Grid Grid.Row="0" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Exprot"
                    Width="90" FontSize="15"                        
                    Style="{StaticResource PrimaryButtonStyle}"
                    />
                <Button Grid.Column="1" Content="Import"
                    Width="90" FontSize="15"                        
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="5,0"/>
            </Grid>
            -->

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- View Controls -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Margin="6,0,6,0" BorderBrush="#C9D1D9" BorderThickness="1" CornerRadius="6" Background="#EEF2F6">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="No." FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="Sheet Name" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="Dir" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                            </Border>
                            <Border Grid.Column="3">
                                <TextBlock Text="Views" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" Margin="6"
                             Style="{StaticResource PrimaryListBoxStyle}"
                             x:Name="SheetListBox"                                                         
                             d:ItemsSource="{d:SampleData ItemCount=4}"
                             ItemsSource="{Binding Sheets}"
                            SelectedItem="{Binding SelectedSheet, Mode=TwoWay}">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E1E6EB"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="30"/>

                                    </Grid.ColumnDefinitions>

                                    <!-- No -->
                                    <Border Grid.Column="0" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0" Padding="4,0">
                                        <TextBox Grid.Column="0"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Text="{Binding SheetNumber, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource PrimaryTextBoxStyle}"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                    </Border>

                                    <!-- View Name (Sheet Name) -->
                                    <Border Grid.Column="1" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0" Padding="4,0">
                                        <TextBox Grid.Column="1"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Text="{Binding SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PrimaryTextBoxStyle}"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                    </Border>

                                    <!-- View Direction -->
                                    <Border Grid.Column="2" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0" Padding="2,0">
                                        <Grid Width="72" Height="28">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 선택된 아이콘 표시 -->
                                            <Border Grid.Column="0" Width="32" Height="32"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Background="Transparent"
                                                    IsHitTestVisible="False">
                                                <ContentControl Content="{Binding SelectedViewDirection}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate>
                                                            <Grid Width="28" Height="28">
                                                                <Border Width="24" Height="24"
                                                                        BorderBrush="#2F80D1"
                                                                        BorderThickness="1.8"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                                <Viewbox Width="18" Height="18"
                                                                         Stretch="Uniform"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center">
                                                                    <Grid Width="24" Height="24">
                                                                        <Grid x:Name="CenterIcon" Visibility="Collapsed">
                                                                            <Ellipse Width="5" Height="5" Fill="#2F80D1"
                                                                                     HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"/>
                                                                        </Grid>

                                                                        <Grid x:Name="HorizontalIcon" Visibility="Collapsed">
                                                                            <Line X1="6" Y1="14" X2="18" Y2="14"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                            <Line X1="18" Y1="14" X2="15" Y2="11"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                            <Line X1="18" Y1="14" X2="15" Y2="17"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        </Grid>

                                                                        <Grid x:Name="VerticalIcon" Visibility="Collapsed">
                                                                            <Line X1="14" Y1="6" X2="14" Y2="18"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                            <Line X1="14" Y1="18" X2="11" Y2="15"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                            <Line X1="14" Y1="18" X2="17" Y2="15"
                                                                                  Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        </Grid>

                                                                        <Grid x:Name="ZHorizontalIcon" Visibility="Collapsed">
                                                                            <Path Stroke="#2F80D1"
                                                                                  StrokeThickness="1.8"
                                                                                  StrokeStartLineCap="Square"
                                                                                  StrokeEndLineCap="Square"
                                                                                  Data="M7,8 L18,8 L10,16 L18,16" />
                                                                            <Polygon Points="18,12 22,16 18,20"
                                                                                     Fill="#2F80D1"/>
                                                                        </Grid>

                                                                        <Grid x:Name="ZVerticalIcon" Visibility="Collapsed">
                                                                            <Path Stroke="#2F80D1"
                                                                                  StrokeThickness="1.8"
                                                                                  StrokeStartLineCap="Square"
                                                                                  StrokeEndLineCap="Square"
                                                                                  Data="M8,7 L8,18 L16,10 L16,18" />
                                                                            <Polygon Points="12,18 16,22 20,18"
                                                                                     Fill="#2F80D1"/>
                                                                        </Grid>
                                                                    </Grid>
                                                                </Viewbox>                                                                
                                                            </Grid>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Center">
                                                                    <Setter TargetName="CenterIcon" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Horizontal">
                                                                    <Setter TargetName="HorizontalIcon" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Vertical">
                                                                    <Setter TargetName="VerticalIcon" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="ZHorizontal">
                                                                    <Setter TargetName="ZHorizontalIcon" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="ZVertical">
                                                                    <Setter TargetName="ZVerticalIcon" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </Border>

                                            <!-- 화살표 있는 실제 ComboBox -->
                                            <ComboBox Grid.Column="1"
                                                      Width="22"
                                                      Height="24"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      ItemsSource="{Binding ViewDirections}"
                                                      SelectedItem="{Binding SelectedViewDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalContentAlignment="Center"
                                                      VerticalContentAlignment="Center">
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>

                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="36" Height="36">
                                                            <Border Width="28" Height="28"
                                                                    BorderBrush="#2F80D1"
                                                                    BorderThickness="1.8"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            <Viewbox Width="20" Height="20"
                                                                     Stretch="Uniform"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                                <Grid Width="24" Height="24">
                                                                    <Grid x:Name="CenterIcon" Visibility="Collapsed">
                                                                        <Ellipse Width="5" Height="5" Fill="#2F80D1"
                                                                                 HorizontalAlignment="Center"
                                                                                 VerticalAlignment="Center"/>
                                                                    </Grid>

                                                                    <Grid x:Name="HorizontalIcon" Visibility="Collapsed">
                                                                        <Line X1="6" Y1="14" X2="18" Y2="14"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        <Line X1="18" Y1="14" X2="15" Y2="11"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        <Line X1="18" Y1="14" X2="15" Y2="17"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                    </Grid>

                                                                    <Grid x:Name="VerticalIcon" Visibility="Collapsed">
                                                                        <Line X1="14" Y1="6" X2="14" Y2="18"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        <Line X1="14" Y1="18" X2="11" Y2="15"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                        <Line X1="14" Y1="18" X2="17" Y2="15"
                                                                              Stroke="#2F80D1" StrokeThickness="1.8"/>
                                                                    </Grid>

                                                                    <Grid x:Name="ZHorizontalIcon" Visibility="Collapsed">
                                                                        <Path Stroke="#2F80D1"
                                                                              StrokeThickness="1.8"
                                                                              StrokeStartLineCap="Square"
                                                                              StrokeEndLineCap="Square"
                                                                              Data="M7,8 L18,8 L10,16 L18,16" />
                                                                        <Polygon Points="18,12 22,16 18,20"
                                                                                 Fill="#2F80D1"/>
                                                                    </Grid>

                                                                    <Grid x:Name="ZVerticalIcon" Visibility="Collapsed">
                                                                        <Path Stroke="#2F80D1"
                                                                              StrokeThickness="1.8"
                                                                              StrokeStartLineCap="Square"
                                                                              StrokeEndLineCap="Square"
                                                                              Data="M8,7 L8,18 L16,10 L16,18" />
                                                                        <Polygon Points="12,18 16,22 20,18"
                                                                                 Fill="#2F80D1"/>
                                                                    </Grid>
                                                                </Grid>
                                                            </Viewbox>                                                            
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Center">
                                                                <Setter TargetName="CenterIcon" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Horizontal">
                                                                <Setter TargetName="HorizontalIcon" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Vertical">
                                                                <Setter TargetName="VerticalIcon" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="ZHorizontal">
                                                                <Setter TargetName="ZHorizontalIcon" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="ZVertical">
                                                                <Setter TargetName="ZVerticalIcon" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </Border>


                                    <!-- Views -->
                                    <Border Grid.Column="3" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0" Padding="4,0">

                                        <ItemsControl ItemsSource="{Binding Views}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="2,0" Padding="4,2" CornerRadius="4" Background="#E8EEF4">
                                                        <StackPanel  Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ViewName}" Margin="0,0,4,0" TextAlignment="Center"/>
                                                            <TextBlock Text="{Binding ViewType}" Foreground="#666" Margin="0,0,6,0" TextAlignment="Center"/>
                                                            <Button Content="··" Width="20" Height="20" Margin="4,0,0,0"
                                                                    Command="{Binding DataContext.ChangeViewCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- Add View -->
                                    <Border Grid.Column="4" BorderBrush="#C9D1D9" BorderThickness="0,0,0,0">
                                        <Button Grid.Column="4" Height ="20" Width="20"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.AddViewCommand, 
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <Image Source="/DHBIMWATER.UI;component/Resources/Icons/ViewPlus.png"
                                                   Width="18" Height="18"/>
                                        </Button>
                                    </Border>

                                    <!-- Remove View -->
                                    <Border Grid.Column="5" BorderBrush="#C9D1D9" BorderThickness="0,0,0,0">
                                        <Button Height="20" Width="20"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.RemoveViewCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <Image Source="/DHBIMWATER.UI;component/Resources/Icons/Trash.png"
                                               Width="18" Height="18"/>
                                        </Button>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom: Buttons -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="OK"
                Width="90" FontSize="15"                        
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding ConfirmCommand}"
                IsDefault="True"/>
                
                <Button Grid.Column="1" Content="Cancel"
                Width="90" FontSize="15"                        
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding CancelCommand}"
                Margin="5,0,5,0" IsCancel="True"/>
            </Grid>

            <Grid Grid.Row="0" HorizontalAlignment="Left" Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Dimension"
                        Width="120" FontSize="15"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding DimensionCommand}"/>
                <Button Grid.Column="1" Content="Annotate"
                        Width="120" FontSize="15" Margin="5,0"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AnnotateCommand}"/>
                <Button Grid.Column="2" Content="배수지용"
                        Width="120" FontSize="15" Margin="5,0"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding WaterReservoirCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
