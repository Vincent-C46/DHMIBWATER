<Window x:Class="DHBIMWATER.UI.Views.Documentation.Sheets.AnnotateSelectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:behaviors="clr-namespace:DHBIMWATER.UI.Behaviors"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        behaviors:DialogResultBehavior.DialogResult="{Binding DialogResult}"
        mc:Ignorable="d"
        Title="태그 패밀리 선택"
        Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9"
        AllowsTransparency="False"
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 사용 가능한 태그 -->
            <GroupBox Header="사용 가능한 태그" Grid.Column="0" Margin="5">
                <ListBox ItemsSource="{Binding AvailableTags}"
                         SelectionMode="Extended"
                         DisplayMemberPath="Name"
                         behaviors:ListBoxSelectedItemsBehavior.SelectedItems="{Binding AvailableSelectedItems}"/>
            </GroupBox>

            <!-- 이동 버튼 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5">
                <Button Width="40" Margin="0,5"
                        Command="{Binding SelectAllCommand}" Style="{StaticResource IconButtonStyle}">
                    <iconPacks:PackIconPixelartIcons Kind="ReplyAll" Width="20" Height="20"
                                                      RenderTransformOrigin="0.5,0.5">
                        <iconPacks:PackIconPixelartIcons.RenderTransform>
                            <ScaleTransform ScaleX="-1"/>
                        </iconPacks:PackIconPixelartIcons.RenderTransform>
                    </iconPacks:PackIconPixelartIcons>
                </Button>
                <Button Width="40" Margin="0,5"
                        Command="{Binding MoveToSelectedCommand}" Style="{StaticResource IconButtonStyle}">
                    <iconPacks:PackIconBootstrapIcons Kind="ArrowRightSquareFill" Width="20" Height="20"/>
                </Button>
                <Button Width="40" Margin="0,5"
                        Command="{Binding MoveToAvailableCommand}" Style="{StaticResource IconButtonStyle}">
                    <iconPacks:PackIconBootstrapIcons Kind="ArrowLeftSquareFill" Width="20" Height="20"/>
                </Button>
                <Button Width="40" Margin="0,5"
                        Command="{Binding DeselectAllCommand}" Style="{StaticResource IconButtonStyle}">
                    <iconPacks:PackIconPixelartIcons Kind="ReplyAll" Width="20" Height="20"/>
                </Button>
            </StackPanel>

            <!-- 선택된 태그 -->
            <GroupBox Header="선택된 태그" Grid.Column="2" Margin="5">
                <ListBox ItemsSource="{Binding SelectedTags}"
                         SelectionMode="Extended"
                         DisplayMemberPath="Name"
                         behaviors:ListBoxSelectedItemsBehavior.SelectedItems="{Binding ChosenSelectedItems}"/>
            </GroupBox>
        </Grid>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="확인" Width="90" FontSize="15" Margin="0,0,10,0"
                    Command="{Binding ConfirmCommand}" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True"/>
            <Button Content="취소" Width="90" FontSize="15"
                    Command="{Binding CancelCommand}" Style="{StaticResource PrimaryButtonStyle}" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
