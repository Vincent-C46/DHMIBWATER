<Window x:Class="DHBIMWATER.UI.Views.Documentation.Sheets.ViewManageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:behaviors="clr-namespace:DHBIMWATER.UI.Behaviors"
        behaviors:DialogResultBehavior.DialogResult="{Binding DialogResult}"
        mc:Ignorable="d"
        Title="View Manage"
        Height="470" Width="951"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9"
        AllowsTransparency="False"
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <!-- Top: Buttons -->
        <Grid Grid.Row="1" Margin="12,10,12,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="530"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="95"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="VIEW TYPE" Margin="0,5,0,5" HorizontalAlignment="Center"
                               Foreground="{Binding TextBlock}"/>
                    <ComboBox Margin="0,0,0,10"
                              ItemsSource="{Binding ViewTypes}"
                              SelectedItem="{Binding SelectedViewType, Mode=TwoWay}"
                              Style="{StaticResource PrimaryComboBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="비주얼 스타일(All)" Margin="0,5,0,5" HorizontalAlignment="Center"
                               Foreground="{Binding TextBlock}"/>
                    <ComboBox Margin="0,0,0,10"
                              ItemsSource="{Binding BulkVisualStyleOptions}"
                              SelectedItem="{Binding SelectedBulkVisualStyle, Mode=TwoWay}"
                              Style="{StaticResource PrimaryComboBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="뷰 축척(All)" Margin="0,5,0,5" HorizontalAlignment="Center"                               
                               Foreground="{Binding TextBlock}"/>
                    <ComboBox Margin="0,0,0,10"
                              ItemsSource="{Binding BulkScaleOptions}"
                              SelectedItem="{Binding SelectedBulkScale, Mode=TwoWay}"
                              Style="{StaticResource PrimaryComboBoxStyle}"/>

                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="양식(All)" Margin="0,5,0,5" HorizontalAlignment="Center"
                               Foreground="{Binding TextBlock}"/>
                    <ComboBox Margin="0,0,0,10"
                              ItemsSource="{Binding BulkSheetFormOptions}"
                              SelectedItem="{Binding SelectedBulkSheetForm, Mode=TwoWay}"
                              Style="{StaticResource PrimaryComboBoxStyle}"/>

                </StackPanel>
            </Grid>

            <!-- VIew List Header -->
            <Grid Grid.Row="1" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="View List" Margin="0,5,0,5" Foreground="{Binding TextBlock}"/>
                    <Border BorderBrush="#C9D1D9" BorderThickness="1" CornerRadius="4" Background="#EEF2F6" Margin="0,0,4,4">
                        <Grid Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="상세번호" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="구분" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="뷰 이름" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="3" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="시트의 제목" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="4" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="비주얼 스타일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="5" BorderBrush="#C9D1D9" BorderThickness="0,0,1,0">
                                <TextBlock Text="뷰 축척" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="6">
                                <TextBlock Text="양식" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- VIew List -->
                    <ListBox d:ItemsSource="{d:SampleData ItemCount=2}" 
                             ItemsSource="{Binding Views}"
                             SelectedItem="{Binding SelectedView, Mode=TwoWay}"
                             Height="234" Margin="0,0,4,10">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderBrush" Value="#E1E6EB"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4" Height="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 상세번호 -->
                                    <Border Grid.Column="0" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
                                        <TextBox Text="{Binding No, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalContentAlignment="Center"
                                                       VerticalContentAlignment="Center"
                                                       BorderThickness="0,0,0,0"
                                                       Background="Transparent"/>
                                    </Border>
                                    
                                    <!-- 구분 -->
                                    <Border Grid.Column="1" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
                                        <TextBlock Text="{Binding ViewType}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"                                                        
                                                         TextAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- 뷰 이름 -->
                                    <Border Grid.Column="2" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
                                        <TextBlock Text="{Binding ViewName}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         TextAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- 시트의 제목 -->
                                    <Border Grid.Column="3" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
                                        <TextBox Text="{Binding SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalContentAlignment="Center"
                                                       VerticalContentAlignment="Center"
                                                       BorderThickness="0"
                                                       Background="Transparent"/>
                                    </Border>

                                    <!-- 비주얼 스타일 -->
                                    <Border Grid.Column="4" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0" >
                                        <ComboBox Margin="2,0,2,0"
                                                  ItemsSource="{Binding DataContext.VisualStyleOptions, 
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding VisualStyle, Mode=TwoWay, 
                                                  UpdateSourceTrigger=PropertyChanged}"                                                  
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  Background="Transparent"/>
                                    </Border>

                                    <!-- 뷰 축척(ComboBox) -->
                                    <Border Grid.Column="5" BorderThickness="0,0,0,0" Margin="2,0,0,0">
                                        <ComboBox ItemsSource="{Binding DataContext.ViewScaleOptions, 
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding ScaleText, Mode=TwoWay, 
                                                  UpdateSourceTrigger=PropertyChanged}"                                              
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  Background="Transparent"/>
                                    </Border>
                                    
                                    <!-- 뷰 축척(TextBox) -->
                                    <Border Grid.Column="6" BorderBrush="#E1E6EB" BorderThickness="0,0,1,0">
                                        <TextBox Text="{Binding ScaleInput, Mode=TwoWay, 
                                                 UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding IsCustomScaleEnabled}"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 BorderThickness="0"
                                                 Background="Transparent"/>
                                    </Border>

                                    <!-- 양식 -->
                                    <Border Grid.Column="7" BorderThickness="0,0,0,0" >
                                        <ComboBox Margin="2,0,2,0"
                                                  ItemsSource="{Binding DataContext.SheetFormOptions, 
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SheetForm, Mode=TwoWay, 
                                                  UpdateSourceTrigger=PropertyChanged}"                                                  
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  Background="Transparent"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>            

            <Grid Grid.Row="2" HorizontalAlignment="Right" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="OK"
                        Width="90" FontSize="15"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ConfirmCommand}"
                        IsDefault="True"/>
                
                <Button Grid.Column="1" Content="Cancel"
                        Width="90" FontSize="15"                        
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Margin="5,0,0,0" IsCancel="True"/>
                
            </Grid>
        </Grid>
    </Grid>
</Window>

