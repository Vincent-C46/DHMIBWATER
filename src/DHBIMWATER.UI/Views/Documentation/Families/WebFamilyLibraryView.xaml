<Window x:Class="DHBIMWATER.UI.Views.Documentation.Families.WebFamilyLibraryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:DHBIMWATER.UI.Behaviors"
        behaviors:DialogResultBehavior.DialogResult="{Binding DialogResult}"
        mc:Ignorable="d"
        Title="Web Family Library"
        Height="680"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1"
                    Content="목록 불러오기"
                    Command="{Binding LoadFamiliesCommand}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      Margin="0,0,12,0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Families}"
                      SelectedItem="{Binding SelectedFamily}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="*" />
                    <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="선택 항목" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="이름" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedFamily.Name}" Margin="0,0,0,10"/>

                    <TextBlock Text="카테고리" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedFamily.Category}" Margin="0,0,0,10"/>

                    <TextBlock Text="설명" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedFamily.Description}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="다운로드 URL" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SelectedFamily.DownloadUrl}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="120"
                             VerticalScrollBarVisibility="Auto"/>

                    <Button Content="선택 항목 로드"
                            Margin="0,12,0,0"
                            Height="32"
                            Command="{Binding LoadFamilyCommand}" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}" />
            <Button DockPanel.Dock="Right"
                    Width="100"
                    Content="닫기"
                    Command="{Binding CloseCommand}" />
        </DockPanel>
    </Grid>
</Window>
