<Window x:Class="DHBIMWATER.UI.Views.Quantity.QuantityView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:vm="clr-namespace:DHBIMWATER.UI.ViewModels.Quantity"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:QuantityViewModel, IsDesignTimeCreatable=False}"
        Title="DHBIM WATER - Quantity Calculator"
        SizeToContent="WidthAndHeight"
        MinWidth="600" MinHeight="400"
        MaxWidth="1200" MaxHeight="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7F9" 
        AllowsTransparency="False" 
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <Border Grid.Row="1"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,0,1"
            Background="#FFFFFF"
            Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="120"
                    Command="{Binding ExtractCommand}" Padding="14,6"  Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xe72c;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="수량 재산출" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Export to" Style="{StaticResource BoldTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="CSV" Width="60"
                    Command="{Binding ExportCsvCommand}"
                    Style="{StaticResource ExportButtonStyle}"
                    Margin="0,0,6,0"/>
                    <Button Content="JSON" Width="60"
                    Command="{Binding ExportJsonCommand}"
                    Style="{StaticResource ExportButtonStyle}"
                    Margin="0,0,6,0"/>
                    <Button Content="Excel" Width="60"
                    Command="{Binding ExportExcelCommand}"
                    Style="{StaticResource ExportButtonStyle}"
                    Margin="0,0,6,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- MainPanel -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- SummaryCards -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!--
                <Border Grid.Row="0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                    <UniformGrid Columns="3" Rows="1">
                        <Border Background="#F1EFE8" CornerRadius="8"
                            Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="콘크리트" FontSize="10" Foreground="#888780"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding TotalConcrete, StringFormat=F1}"
                                           FontSize="18" FontWeight="Medium"/>
                                    <TextBlock Text=" m³" FontSize="10"
                                           Foreground="#888780" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="#F1EFE8" CornerRadius="8"
                            Padding="12,8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="거푸집" FontSize="10" Foreground="#888780"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding TotalFormwork, StringFormat=F1}"
                                           FontSize="18" FontWeight="Medium"/>
                                    <TextBlock Text=" m²" FontSize="10"
                                           Foreground="#888780" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="#FCEBEB" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="미완료 항목" FontSize="10" Foreground="#A32D2D"/>
                                <TextBlock Text="{Binding IncompleteCount}"
                                       FontSize="18" FontWeight="Medium"
                                       Foreground="#E24B4A"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </Border>
                -->

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                      ItemsSource="{Binding QuantityItems}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      FontSize="11"
                      RowHeight="28"
                      BorderThickness="0"
                      Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="카테고리"   Binding="{Binding Category}"     Width="70"/>
                        <DataGridTextColumn Header="ElementId"  Binding="{Binding ElementId}"    Width="70"/>
                        <DataGridTextColumn Header="코드"       Binding="{Binding ElementCode}"  Width="60"/>
                        <DataGridTextColumn Header="공종"       Binding="{Binding WorkType}"     Width="90"/>
                        <DataGridTextColumn Header="규격"       Binding="{Binding Specification}" Width="80"/>
                        <DataGridTextColumn Header="재료"       Binding="{Binding Material}"     Width="80"/>
                        <DataGridTextColumn Header="산출식"     Binding="{Binding Formula}"      Width="*"/>
                        <DataGridTextColumn Header="값"         Binding="{Binding Value, StringFormat=F2}" Width="60"/>
                        <DataGridTextColumn Header="단위"       Binding="{Binding Unit}"         Width="44"/>
                        <!--
                    <DataGridTextColumn Header="상태"       Binding="{Binding Status}"       Width="56"/>
                    -->
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="#E2E8F0"
                      ShowsPreview="True"/>

            <!-- SidePanel -->
            <Grid Grid.Column="2" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- DetailSection -->
                    <RowDefinition Height="*"/>
                    <!-- GroupSummary -->
                </Grid.RowDefinitions>

                <!-- DetailSection -->
                <Border Grid.Row="0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="선택 항목"
                               FontSize="10" FontWeight="Medium"
                               Foreground="#888780"
                               Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                                <RowDefinition Height="22"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="카테고리" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedItem.Category}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ElementId" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedItem.ElementId}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="코드" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedItem.ElementCode}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="공종" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedItem.WorkType}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="재료" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedItem.Material}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="산출식" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedItem.Formula}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="값" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" FontSize="11" FontWeight="Medium" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedItem.Value, StringFormat=F2}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SelectedItem.Unit}" Foreground="#888780"/>
                            </TextBlock>
                        </Grid>

                        <!-- Revit 하이라이트 표시 -->
                        <Border Background="#E6F1FB"
                            BorderBrush="#85B7EB"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsItemSelected}">
                            <TextBlock Text="Revit에서 하이라이트됨"
                                   FontSize="11"
                                   Foreground="#0C447C"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- GroupSummary -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                           Text="그룹 집계"
                           FontSize="10" FontWeight="Medium"
                           Foreground="#888780"
                           Padding="14,10,14,6"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,6">
                                        <Grid>
                                            <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Total, StringFormat=F1}"
                                                       FontSize="11" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Unit}"
                                                       FontSize="10" Foreground="#888780"
                                                       Margin="3,0,0,0" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="3"
            BorderBrush="#E2E8F0"
            BorderThickness="0,1,0,0"
            Background="#F8FAFC"
            Padding="16,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#639922" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock FontSize="10" Foreground="#888780" Margin="0,0,12,0">
                    <Run Text="자동 "/><Run Text="{Binding AutoCount}"/>
                    <Run Text="개"/>
                    </TextBlock>
                    <Ellipse Width="6" Height="6" Fill="#BA7517" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock FontSize="10" Foreground="#888780" Margin="0,0,12,0">
                    <Run Text="수동 "/><Run Text="{Binding ManualCount}"/>
                    <Run Text="개"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                       FontSize="10" Foreground="#888780"
                       VerticalAlignment="Center">
                <Run Text="전체 "/><Run Text="{Binding TotalCount}"/><Run Text="개 항목"/>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>