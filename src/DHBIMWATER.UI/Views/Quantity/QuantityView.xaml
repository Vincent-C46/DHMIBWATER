<Window x:Class="DHBIMWATER.UI.Views.Quantity.QuantityView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:vm="clr-namespace:DHBIMWATER.UI.ViewModels.Quantity"
        xmlns:conv="clr-namespace:DHBIMWATER.UI.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:QuantityViewModel, IsDesignTimeCreatable=False}"
        Title="DHBIM WATER - Quantity Calculator"
        Width="980" Height="700"
        MinWidth="700" MinHeight="450"
        MaxWidth="1500" MaxHeight="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F4F7F9" 
        AllowsTransparency="False" 
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!--
            <CollectionViewSource x:Key="GroupedByWorkType"
                              Source="{Binding QuantityItems}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="WorkType"/>
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>
            -->

            <conv:GroupElementCountConverter x:Key="ElementCountConverter"/>

            <CollectionViewSource x:Key="SummaryItemsSource"
                              Source="{Binding SummaryItems}"/>

            <CollectionViewSource x:Key="GroupByMembers" Source="{Binding QuantityItems}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Category"/>
                    <PropertyGroupDescription PropertyName="ElementCode"/>
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Command="{Binding DeleteItemCommand}" Key="Delete"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <Border Grid.Row="1"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,0,1"
            Background="#FFFFFF"
            Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Width="120" Command="{Binding ExtractCommand}"
                            Padding="14,6" Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/refresh-arrow_white.png" Width="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="수량 재산출" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="80" Command="{Binding AddManualItemCommand}"
                            Padding="14,6" Margin="8,0,0,0" Style="{StaticResource ExportButtonStyle}"
                            BorderThickness="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/add.png" Width="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="추가" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="80" Command="{Binding DeleteItemCommand}"
                            Padding="14,6" Margin="8,0,0,0" Style="{StaticResource ExportButtonStyle}"
                            BorderThickness="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/delete.png" Width="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="삭제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="80" Command="{Binding CopyItemCommand}"
                            Padding="14,6" Margin="8,0,0,0" Style="{StaticResource ExportButtonStyle}"
                            BorderThickness="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/copy.png" Width="17" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="복사" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="80" Command="{Binding EditItemCommand}"
                            Padding="14,6" Margin="8,0,0,0" Style="{StaticResource ExportButtonStyle}"
                            BorderThickness="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/edit.png" Width="17" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="수정" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Export to" Style="{StaticResource BoldTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <!--
                    <Button Content="JSON" Width="60"
                    Command="{Binding ExportJsonCommand}"
                    Style="{StaticResource ExportButtonStyle}"
                    Margin="0,0,6,0"/>
                    -->
                    <Button Width="100" Command="{Binding ExportToExcelCommand}"
                            Padding="14,6" Margin="8,0,0,0" Style="{StaticResource ExportButtonStyle}"
                            BorderThickness="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/DHBIMWATER.UI;component/Resources/Quantity/excel.png" Width="22" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Excel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- MainPanel -->
            <Border Grid.Row="1"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">

                <TabControl Style="{StaticResource PrimaryTabControlStyle}"
                            SelectedIndex="{Binding SelectedTabIndex}">
                    <!-- 공종별 집계 -->
                    <TabItem Header="공종별">
                        <DataGrid ItemsSource="{Binding Source={StaticResource SummaryItemsSource}}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="False"
                                  SelectedItem="{Binding SelectedSummaryItem}"
                                  Style="{StaticResource QuantityDataGridStyle}"
                                  VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="#F1EFE8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="공종"  Binding="{Binding WorkType}"         Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="규격"  Binding="{Binding Specification}"    Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="규격2" Binding="{Binding SubSpecification}" Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="단위"  Binding="{Binding Unit}"             Width="Auto" MinWidth="40"/>
                                <DataGridTextColumn Header="값"    Binding="{Binding Value, StringFormat=F3}" Width="Auto" MinWidth="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- 부재별 집계: 카테고리 → ElementCode 2단 그룹핑 -->
                    <TabItem Header="부재별">
                        <DataGrid ItemsSource="{Binding Source={StaticResource GroupByMembers}}"
                                  SelectedItem="{Binding SelectedItem}"
                                  SelectionMode="Extended"
                                  SelectionChanged="OnItemsSelectionChanged"
                                  PreviewKeyDown="OnDataGridPreviewKeyDown"
                                  Style="{StaticResource QuantityDataGridStyle}"
                                  VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">

                            <!-- 1단 그룹: 카테고리 (진한 배경, 클릭으로 접기/펼치기) -->
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <StackPanel>
                                                            <ToggleButton x:Name="toggle1" IsChecked="True"
                                                                          Padding="0" BorderThickness="0"
                                                                          Focusable="False" Cursor="Hand">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="#2C3E50" Padding="12,6">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <!-- 접기/펼치기 화살표 -->
                                                                                <TextBlock x:Name="arrow"
                                                                                           Grid.Column="0"
                                                                                           Text="▾"
                                                                                           Foreground="White"
                                                                                           FontSize="11"
                                                                                           VerticalAlignment="Center"
                                                                                           Margin="0,0,8,0"/>
                                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               Foreground="White"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                                                                               Foreground="#95A5A6"
                                                                                               FontSize="11"
                                                                                               VerticalAlignment="Bottom"
                                                                                               Margin="4,0,0,1"/>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="False">
                                                                                <Setter TargetName="arrow" Property="Text" Value="▸"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ItemsPresenter x:Name="items1"/>
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger SourceName="toggle1" Property="IsChecked" Value="False">
                                                                <Setter TargetName="items1" Property="Visibility" Value="Collapsed"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>

                                <!-- 2단 그룹: ElementCode (연한 배경, 들여쓰기, 클릭으로 접기/펼치기) -->
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <StackPanel>
                                                            <ToggleButton x:Name="toggle2" IsChecked="True"
                                                                          Padding="0" BorderThickness="0"
                                                                          Focusable="False" Cursor="Hand">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="#E9ECEF" Padding="24,5">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <!-- 접기/펼치기 화살표 -->
                                                                                <TextBlock x:Name="arrow2"
                                                                                           Grid.Column="0"
                                                                                           Text="▾"
                                                                                           Foreground="#34495E"
                                                                                           FontSize="10"
                                                                                           VerticalAlignment="Center"
                                                                                           Margin="0,0,6,0"/>
                                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               Foreground="#34495E"
                                                                                               FontSize="11"
                                                                                               FontWeight="Medium"
                                                                                               FontFamily="Consolas, Courier New"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding Converter={StaticResource ElementCountConverter}, StringFormat=' — {0}개'}"
                                                                                               Foreground="#95A5A6"
                                                                                               FontSize="10"
                                                                                               VerticalAlignment="Bottom"
                                                                                               Margin="4,0,0,1"/>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="False">
                                                                                <Setter TargetName="arrow2" Property="Text" Value="▸"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ItemsPresenter x:Name="items2"/>
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger SourceName="toggle2" Property="IsChecked" Value="False">
                                                                <Setter TargetName="items2" Property="Visibility" Value="Collapsed"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>

                            <!-- 카테고리·코드는 그룹 헤더로 이동했으므로 컬럼에서 제거 -->
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="공종"   Binding="{Binding WorkType}"                Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="규격1"   Binding="{Binding Specification}"                Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="규격2"   Binding="{Binding SubSpecification}"                Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="산출식" Binding="{Binding RenderedFormula}"         Width="Auto"   MinWidth="80"/>
                                <DataGridTextColumn Header="값"     Binding="{Binding Value, StringFormat=F3}"  Width="Auto" MinWidth="60"/>
                                <DataGridTextColumn Header="단위"   Binding="{Binding Unit}"                    Width="Auto" MinWidth="40"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- 상세 목록 -->
                    <TabItem Header="상세 목록">
                        <DataGrid ItemsSource="{Binding QuantityItems}"
                                  SelectedItem="{Binding SelectedItem}"
                                  SelectionMode="Extended"
                                  SelectionChanged="OnItemsSelectionChanged"
                                  PreviewKeyDown="OnDataGridPreviewKeyDown"
                                  Style="{StaticResource QuantityDataGridStyle}"
                                  VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="카테고리"  Binding="{Binding Category}"                Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="ElementId" Binding="{Binding ElementId}"               Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="코드"      Binding="{Binding ElementCode}"             Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="공종"      Binding="{Binding WorkType}"                Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="규격1"      Binding="{Binding Specification}"           Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="규격2"      Binding="{Binding SubSpecification}"           Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="산출식"    Binding="{Binding RenderedFormula}"         Width="1*"   MinWidth="50"/>
                                <DataGridTextColumn Header="값"        Binding="{Binding Value, StringFormat=F3}"  Width="Auto" MinWidth="50"/>
                                <DataGridTextColumn Header="단위"      Binding="{Binding Unit}"                    Width="Auto" MinWidth="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="#E2E8F0"
                      ShowsPreview="True"/>

            <!-- SidePanel -->
            <Grid Grid.Column="2" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- DetailSection -->
                    <RowDefinition Height="*"/>
                    <!-- GroupSummary -->
                </Grid.RowDefinitions>

                <!-- DetailSection -->
                <Border Grid.Row="0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="선택 항목"
                               FontSize="10" FontWeight="Medium"
                               Foreground="#888780"
                               Margin="0,0,0,8"/>
                        <Border>
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="카테고리" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" Text="{Binding SelectedItem.Category}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="ElementId" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" Text="{Binding SelectedItem.ElementId}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="코드" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" Text="{Binding SelectedItem.ElementCode}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="공종" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" Text="{Binding SelectedItem.WorkType}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="산출식" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" Text="{Binding SelectedItem.RenderedFormula}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Height = "22">
                                    <TextBlock Width="90" Text="값" FontSize="11" Foreground="#888780" VerticalAlignment="Center"/>
                                    <TextBlock Width="150" Style="{StaticResource BodyTextBlockStyle}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Run Text="{Binding SelectedItem.Value, StringFormat=F2}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding SelectedItem.Unit}" Foreground="#888780"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Revit 하이라이트 표시 -->
                        <Border Background="#E6F1FB"
                            BorderBrush="#85B7EB"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsItemSelected}">
                            <TextBlock Text="Revit에서 하이라이트됨"
                                   FontSize="11"
                                   Foreground="#0C447C"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- GroupSummary -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                           Text="그룹 집계"
                           FontSize="10" FontWeight="Medium"
                           Foreground="#888780"
                           Padding="14,10,14,6"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupSummaries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,5">
                                        <Grid>
                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                <TextBlock Text="{Binding Spec}" FontSize="10" Foreground="#888780">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Spec}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ValueDisplay}"
                                                       FontSize="11" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Unit}"
                                                       FontSize="10" Foreground="#888780"
                                                       Margin="3,0,0,0" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- StatusBar -->
        <Border Grid.Row="3"
            BorderBrush="#E2E8F0"
            BorderThickness="0,1,0,0"
            Background="#F8FAFC"
            Padding="16,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="#639922" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock FontSize="10" Foreground="#888780" Margin="0,0,12,0">
                    <Run Text="자동 "/><Run Text="{Binding AutoCount}"/>
                    <Run Text="개"/>
                    </TextBlock>
                    <Ellipse Width="6" Height="6" Fill="#BA7517" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock FontSize="10" Foreground="#888780" Margin="0,0,12,0">
                    <Run Text="수동 "/><Run Text="{Binding ManualCount}"/>
                    <Run Text="개"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                       FontSize="10" Foreground="#888780"
                       VerticalAlignment="Center">
                <Run Text="전체 "/><Run Text="{Binding TotalCount}"/><Run Text="개 항목"/>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>