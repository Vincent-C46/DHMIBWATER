<Window x:Class="DHBIMWATER.UI.Views.Quantity.ManualQuantityView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:vm="clr-namespace:DHBIMWATER.UI.ViewModels.Quantity"
        xmlns:conv="clr-namespace:DHBIMWATER.UI.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:ManualQuantityViewModel, IsDesignTimeCreatable=False}"
        Title="{Binding Title}"
        Width="520" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9"
        WindowStyle="None"
        AllowsTransparency="False"
        FontFamily="Segoe UI, Malgun Gothic"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- TitleBar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <controls:TitleBar Grid.Row="0"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,10,20,10">
            <StackPanel>

                <!-- 필수 항목 -->
                <TextBlock Text="필수 항목"
                           FontSize="10" FontWeight="Medium"
                           Foreground="#888780"
                           Margin="0,10,0,8"/>

                <!-- 공종 + 단위 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="공종 *" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding WorkType, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PrimaryTextBoxStyle}"
                                 Height="32"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="단위 *" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding UnitOptions}"
                                  SelectedItem="{Binding Unit}"
                                  Height="32"/>
                    </StackPanel>
                </Grid>

                <!-- 산출식 -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="산출식 *" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8">
                        <StackPanel>
                            <TextBox Text="{Binding RawFormula, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Height="28"/>
                            <TextBlock Text="영문+숫자 조합으로 변수 입력 (예: B1, H, L1)"
                                       FontSize="10"
                                       Foreground="#888780"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 변수 입력란 (동적 생성) -->
                <Border Visibility="{Binding HasVariables, Converter={StaticResource BoolToVisibility}}"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,10"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="변수 입력"
                                   FontSize="10" FontWeight="Medium"
                                   Foreground="#888780"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding VariableInputs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,0,6,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="#888780"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     GotFocus="VariableTextBox_GotFocus"
                                                     PreviewTextInput="VariableTextBox_PreviewTextInput"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontSize="12"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Unit}"
                                                       FontSize="10"
                                                       Foreground="#888780"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 산출 미리보기 -->
                <Border Visibility="{Binding HasVariables, Converter={StaticResource BoolToVisibility}}"
                        Background="#E6F1FB"
                        BorderBrush="#85B7EB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="산출 미리보기"
                                   FontSize="10"
                                   Foreground="#185FA5"
                                   Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding Preview}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#0C447C"/>
                    </StackPanel>
                </Border>

                <Separator Background="#E2E8F0" Margin="0,4,0,12"/>

                <!-- 선택 항목 -->
                <TextBlock Text="선택 항목"
                           FontSize="10" FontWeight="Medium"
                           Foreground="#888780"
                           Margin="0,0,0,8"/>

                <Border BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="카테고리" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Category}"
                                         Style="{StaticResource PrimaryTextBoxStyle}"
                                         Height="32"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ElementCode" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ElementCode}"
                                         Style="{StaticResource PrimaryTextBoxStyle}"
                                         Height="32"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="규격" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Specification}"
                                         Style="{StaticResource PrimaryTextBoxStyle}"
                                         Height="32"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="규격2" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SubSpecification}"
                                         Style="{StaticResource PrimaryTextBoxStyle}"
                                         Height="32"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Background="#F8FAFC"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="취소"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelButtonStyle}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            FontSize="12"/>
                    <Button Content="{Binding ConfirmButtonText}"
                            Command="{Binding ConfirmCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="16,8"
                            FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
