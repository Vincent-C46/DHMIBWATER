<Window x:Class="DHBIMWATER.UI.Views.Modeling.PumpingStationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:vm="clr-namespace:DHBIMWATER.UI.ViewModels.Modeling"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:PumpingStationViewModel, IsDesignTimeCreatable=False}"
        
        Title="DHBIM WATER - WTank Builder" 
        Height="Auto" Width="Auto" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9" 
        AllowsTransparency="False" 
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0" Grid.ColumnSpan="2"/>

        <Grid Grid.Row="1" Margin="30,10,30,10" Width="Auto">
            <Border Grid.Column="1" Background="White" CornerRadius="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#DDE4EB" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <TabControl Style="{StaticResource PrimaryTabControlStyle}" Margin="20" Height="Auto">
                        <!--설계조건 탭-->
                        <TabItem Header="설계조건" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="D:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 구경" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding D}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"
                                                           Width="50"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="HD:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="양정고" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding HD}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="N:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 대수" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding N}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="개" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="LWL:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="저수위 (EL)" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding LWL}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="HWL:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="고수위 (EL)" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding HWL}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <!--
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/Images/0-1.설계조건.png"
                                                   Width="450"/>
                                            -->
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!--종단제원 탭-->
                        <TabItem Header="종단제원" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 관리공간 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B1}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B3:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 오프닝~건축격벽" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B3}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B4:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 유지관리 공간 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B4}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B5:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 오프닝 사이즈" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B5}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B6:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="돌출부 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B6}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B7:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="밸브실 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding B7}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="H1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 최소 운전 수위" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding H1}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>



                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/PumpStationImages/1-2.펌프장_종단제원.png" Width="600"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!--평면제원 탭-->
                        <TabItem Header="평면제원" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="He:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="유효수심" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m (Min 3m ~ Max 6m)" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Hf:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="여유고" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m (Min 0.3m)" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Hm:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="수조부 바닥 ~ LWL 높이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m (Min 0.15m)" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="W:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="지 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="L:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="지 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="M:" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="기둥 Margin" Width="150" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="상(M1): " Width="50" VerticalAlignment="Center" Margin="10, 0"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" Text="{Binding M1, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                         Width="30" Height="25" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="m /" Width="30" Margin="10, 0" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="하(M2): " Width="50" VerticalAlignment="Center" Margin="10, 0"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" Text="{Binding M1, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                         Width="30" Height="25" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="mm" Width="30" Margin="10, 0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="" Width="180"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="좌(M3): " Width="50" VerticalAlignment="Center" Margin="10, 0"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" Text="{Binding M1, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                         Width="30" Height="25" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="m /" Width="30" Margin="10, 0" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="우(M4): " Width="50" VerticalAlignment="Center" Margin="10, 0"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" Text="{Binding M1, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                         Width="30" Height="25" VerticalAlignment="Center"/>
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="mm" Width="30" Margin="10, 0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="" Width="180"/>

                                                <TextBlock Style ="{StaticResource LabelTextBlockStyle}" Text="(기둥간 중심간격 5m 이내 등간격 자동배치)" Width="300" Margin="12 5 0 12"/>
                                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Wh:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="수조부 Hopper 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Lh:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="수조부 Hopper 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Hh:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="수조부 Hopper 깊이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Ltt:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="기초 Toe 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                      Text="{Binding TextBoxContent}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>

                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/PumpStationImages/1-1.펌프장_평면제원.png" Width="450"/>
 
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!--부재 유형 탭-->
                        <TabItem Header="부재 유형" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="450"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <!--슬래브 유형-->
                                            <TextBlock Style ="{StaticResource BaseTextBlockStyle}" Text="슬래브" FontSize="15" Margin="10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T1:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="상부슬래브 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T1}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T2:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="기초슬래브 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T2}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T3:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="중간슬래브 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T3}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>

                                            <!--벽체 유형-->
                                            <TextBlock Style ="{StaticResource BaseTextBlockStyle}" Text="벽체" FontSize="15" Margin="10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T4:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text= "외벽 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T1}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T2:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="기초슬래브 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T2}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="T3:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="중간슬래브 두께" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}" 
                                                         Text="{Binding T3}" Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="50"/>
                                            </StackPanel>




                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <!--
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/Images/3-1.부재선택.png" 
                                                   Width="350"/>
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/Images/3-2.부재선택.png" 
                                                   Width="350"/>
                                            -->
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="2">
            <Button Content="Create" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Width="150" Height="40" 
                    HorizontalAlignment="Right" 
                    Margin="0,0,20,20"
                    Command="{Binding CreateWTankCommand}"/>
        </Grid>
    </Grid>
</Window>
