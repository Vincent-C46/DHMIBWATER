<Window x:Class="DHBIMWATER.UI.Views.Modeling.PumpingStationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        xmlns:vm="clr-namespace:DHBIMWATER.UI.ViewModels.Modeling"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:PumpingStationViewModel, IsDesignTimeCreatable=False}"
        
        Title="DHBIM WATER - PumpingStation Builder"
        SizeToContent="Height" Width="1100" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9" 
        AllowsTransparency="False" 
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DHBIMWATER.UI;component/Styles/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="15" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0" Grid.ColumnSpan="2"/>

        <Grid Grid.Row="1" Margin="30,10,30,10" Width="Auto">
            <Border Grid.Column="1" Background="White" CornerRadius="15" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#DDE4EB" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">
                    <TabControl Style="{StaticResource PrimaryTabControlStyle}" Margin="20" Height="Auto">
                        <!--설계조건 탭-->
                        <TabItem Header="설계조건" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="펌프장 타입" Style="{StaticResource LabelTextBlockStyle}" Width="185" VerticalAlignment="Center"/>
                                                <ComboBox Style="{StaticResource PrimaryComboBoxStyle}" 
                                             Width="150" Margin="10,0"
                                             ItemsSource="{Binding PumpingStaitonTypes}"
                                             SelectedItem="{Binding SelectedPumpingStationType}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="진입부 위치" Style="{StaticResource LabelTextBlockStyle}" Width="185" VerticalAlignment="Center"/>
                                                <ComboBox Style="{StaticResource PrimaryComboBoxStyle}" 
                                             Width="150" Margin="10,0,0,5"
                                             ItemsSource="{Binding EntranceTypes}"
                                             SelectedItem="{Binding SelectedEntranceType}"/>
                                            </StackPanel>
                                            <Separator Margin="0,0,0,10"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="D:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 구경" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding D}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="HD:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="양정고" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding HD}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="N:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 대수" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding N}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="대" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="LWL:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="저수위 (EL)" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding LWL}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="HWL:" Style="{StaticResource LabelTextBlockStyle}" Width="35" VerticalAlignment="Center"/>
                                                <TextBlock Text="고수위 (EL)" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource ReservoirTextBoxStyle}"
                                                         Text="{Binding HWL}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="m" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <!--
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/Images/0-1.설계조건.png"
                                                   Width="450"/>
                                            -->
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!--종단제원 탭-->
                        <TabItem Header="종단제원" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 관리공간 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B1}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B3:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 오프닝~건축격벽" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B3}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B4:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 유지관리 공간 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B4}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B6:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="돌출부 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B6}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B7:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="밸브실 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding B7}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="H1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="제진기 최소 운전 수위" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding H1}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="H6:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="밸브받침 높이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding H6}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="L1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="슬래브 단부 길이1" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                        Text="{Binding L1}"
                                                        Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="OB1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="벽체 오프닝 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding OB1}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="OH1:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="벽체 오프닝 높이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding OH1}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="HS:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="계단 높이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding HS}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="θ:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="기초 경사부 기울기" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <ComboBox Style="{StaticResource PrimaryComboBoxStyle}" 
                                                          Width="150" Margin="10,0"
                                                          ItemsSource="{Binding Thetas}"
                                                          SelectedItem="{Binding SelectedTheta}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/PumpStationImages/1-2.펌프장_종단제원.png" Width="600" HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0"  Grid.Row="1" Margin="0,5,0,0">
                                            <Expander x:Name="DownExpander" Grid.Row="1"
                                              IsExpanded="{Binding IsExpanded}"
                                              Visibility="Visible"
                                              ExpandDirection="Down">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Edit Calculated Value"/>
                                                    </StackPanel>
                                                </Expander.Header>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="L2:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="슬래브 단부 길이2" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding L2}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="L3:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="기초 경사부 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding L3}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="L4:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="계단 끝~펌프 중심" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding L4}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="H3:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="여유고" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding H3}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="H4:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="펌프 흡입관 잠김 깊이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding H4}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="H7:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="최소 토피" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding H7}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="NS:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="기초 경사부 계단 단수" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                                 Text="{Binding NS}"
                                                                 Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="단" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>

                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!--평면제원 탭-->
                        <TabItem Header="평면제원" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0" Height="200" VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                                                <TextBlock Text="" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 오프닝 타입" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <RadioButton Content="사각형" GroupName="PumpOpeningType" Margin="10,0" VerticalAlignment="Center" IsChecked="True"/>
                                                <RadioButton Content="원형" GroupName="PumpOpeningType"
                                                             IsChecked="{Binding IsCircularOpening}"
                                                             Margin="10,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B5:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="펌프 오프닝 사이즈" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B5}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B9:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="진입부 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B9}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="B10:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                <TextBlock Text="Toe 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding B10}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="150"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0"  Grid.Row="1" Margin="0,5,0,0" VerticalAlignment="Top">
                                            <Expander x:Name="PlanDownExpander" Grid.Row="1"
                                              IsExpanded="{Binding IsExpanded}"
                                              Visibility="Visible"
                                              ExpandDirection="Down">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Edit Calculated Value"/>
                                                    </StackPanel>
                                                </Expander.Header>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="B2:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="제진기 오프닝 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                       Text="{Binding B2}"
                                       Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="B8:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="제진기 오프닝 폭" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                       Text="{Binding B8}"
                                       Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                        <TextBlock Text="L5:" Style="{StaticResource LabelTextBlockStyle}" Width="30" VerticalAlignment="Center"/>
                                                        <TextBlock Text="진입부 길이" Style="{StaticResource LabelTextBlockStyle}" Width="150" VerticalAlignment="Center"/>
                                                        <TextBox Style="{StaticResource PrimaryTextBoxStyle}"
                                                         Text="{Binding L5}"
                                                         Width="150" Margin="10,0" VerticalAlignment="Center" Height="25"/>
                                                        <TextBlock Text="mm" Style="{StaticResource LabelTextBlockStyle}" VerticalAlignment="Center" Width="30"/>
                                                    </StackPanel>

                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="10,0,0,0" VerticalAlignment="Top">
                                            <Image Source="pack://application:,,,/DHBIMWATER.UI;component/Resources/PumpStationImages/1-1.펌프장_평면제원.png" Width="400" Height="Auto" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!--부재 유형 탭-->
                        <TabItem Header="부재 유형" Style="{StaticResource PrimaryTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="450"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <!--슬래브 유형-->
                                            <TextBlock Style ="{StaticResource BaseTextBlockStyle}" Text="슬래브" FontSize="15" Margin="10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
