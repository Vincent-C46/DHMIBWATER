<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================
         Primary Colors - 주요 브랜드 색상
         ======================================== -->
    <Color x:Key="Color.Primary">#2196F3</Color>
    <Color x:Key="Color.Primary.Hover">#1E88E5</Color>
    <Color x:Key="Color.Primary.Light">#E3F2FD</Color>

    <!-- ========================================
         Neutral Colors - 중립 색상 (회색 계열)
         ======================================== -->
    <Color x:Key="Color.Neutral.White">#FFFFFF</Color>
    <Color x:Key="Color.Neutral.Gray.50">#FAFBFC</Color>
    <Color x:Key="Color.Neutral.Gray.100">#F8FAFC</Color>
    <Color x:Key="Color.Neutral.Gray.200">#F4F7F9</Color>
    <Color x:Key="Color.Neutral.Gray.300">#E9ECEF</Color>
    <Color x:Key="Color.Neutral.Gray.400">#DDE4EB</Color>
    <Color x:Key="Color.Neutral.Gray.500">#95A5A6</Color>
    <Color x:Key="Color.Neutral.Gray.600">#7F8C8D</Color>
    <Color x:Key="Color.Neutral.Gray.800">#34495E</Color>
    <Color x:Key="Color.Neutral.Gray.900">#2C3E50</Color>

    <!-- ========================================
         Semantic Colors - 의미있는 색상
         ======================================== -->
    <Color x:Key="Color.Success">#27AE60</Color>
    <Color x:Key="Color.Warning">#F39C12</Color>
    <Color x:Key="Color.Error">#E74C3C</Color>
    <Color x:Key="Color.Info">#3498DB</Color>


    <!-- ========================================
         Solid Color Brushes - Primary
         ======================================== -->
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="Brush.Primary.Hover" Color="{StaticResource Color.Primary.Hover}"/>
    <SolidColorBrush x:Key="Brush.Primary.Light" Color="{StaticResource Color.Primary.Light}"/>

    <!-- ========================================
         Solid Color Brushes - Neutral
         ======================================== -->
    <SolidColorBrush x:Key="Brush.White" Color="{StaticResource Color.Neutral.White}"/>
    <SolidColorBrush x:Key="Brush.Gray.50" Color="{StaticResource Color.Neutral.Gray.50}"/>
    <SolidColorBrush x:Key="Brush.Gray.100" Color="{StaticResource Color.Neutral.Gray.100}"/>
    <SolidColorBrush x:Key="Brush.Gray.200" Color="{StaticResource Color.Neutral.Gray.200}"/>
    <SolidColorBrush x:Key="Brush.Gray.300" Color="{StaticResource Color.Neutral.Gray.300}"/>
    <SolidColorBrush x:Key="Brush.Gray.400" Color="{StaticResource Color.Neutral.Gray.400}"/>
    <SolidColorBrush x:Key="Brush.Gray.500" Color="{StaticResource Color.Neutral.Gray.500}"/>
    <SolidColorBrush x:Key="Brush.Gray.600" Color="{StaticResource Color.Neutral.Gray.600}"/>
    <SolidColorBrush x:Key="Brush.Gray.800" Color="{StaticResource Color.Neutral.Gray.800}"/>
    <SolidColorBrush x:Key="Brush.Gray.900" Color="{StaticResource Color.Neutral.Gray.900}"/>

    <!-- ========================================
         Solid Color Brushes - Semantic
         ======================================== -->
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>


    <!-- ========================================
         Legacy Aliases - 기존 코드 호환성
         ======================================== -->
    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource Color.Primary.Hover}"/>

    <!-- Background -->
    <SolidColorBrush x:Key="MainBackgroundBrush" Color="{StaticResource Color.Neutral.Gray.200}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource Color.Neutral.White}"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource Color.Primary.Light}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource Color.Primary.Light}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource Color.Neutral.Gray.100}"/>
    <SolidColorBrush x:Key="AlternatingRowBrush" Color="{StaticResource Color.Neutral.Gray.50}"/>
    <SolidColorBrush x:Key="ProgressBarTrackBrush" Color="{StaticResource Color.Neutral.Gray.300}"/>

    <!-- Border -->
    <SolidColorBrush x:Key="CommonBorderBrush" Color="{StaticResource Color.Neutral.Gray.400}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Color.Neutral.Gray.400}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="MainTextBrush" Color="{StaticResource Color.Neutral.Gray.900}"/>
    <SolidColorBrush x:Key="TextSubBrush" Color="{StaticResource Color.Neutral.Gray.600}"/>

</ResourceDictionary>
