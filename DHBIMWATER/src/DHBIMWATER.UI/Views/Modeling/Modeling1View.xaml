<Window x:Class="DHBIMWATER.UI.Views.Modeling.Modeling1View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:controls="clr-namespace:DHBIMWATER.UI.Controls"
        Title="DHBIM WATER" 
        Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9" 
        AllowsTransparency="False" 
        WindowStyle="None"
        FontFamily="Segoe UI, Malgun Gothic"
        TextOptions.TextFormattingMode="Display"  
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      CornerRadius="15" 
                      GlassFrameThickness="1" 
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <controls:TitleBar Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="30,20,30,10">
            <Border Background="White" CornerRadius="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="2" Color="#DDE4EB" Opacity="0.4"/>
                </Border.Effect>

                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Border Background="#E3F2FD" CornerRadius="8" Padding="8">
                            <iconPacks:PackIconMaterial Kind="Water" Width="24" Height="24" Foreground="#2196F3"/>
                        </Border>
                        <StackPanel Margin="15,0">
                            <TextBlock Text="DH BIM WATER" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                            <TextBlock Text="Next-Gen Modeling Solution" FontSize="11" Foreground="#95A5A6" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="RocketLaunch" Width="70" Height="70" 
                                                   HorizontalAlignment="Center" Foreground="#34495E" Margin="0,0,0,25">
                            <iconPacks:PackIconMaterial.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#2196F3" Opacity="0.2"/>
                            </iconPacks:PackIconMaterial.Effect>
                        </iconPacks:PackIconMaterial>

                        <TextBlock Text="환영합니다, 팀원 여러분!" 
                                   FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2C3E50"/>
                        <TextBlock Text="스마트한 워크플로우를 위한 모델링 준비가 완료되었습니다." 
                                   FontSize="14" Margin="0,12,0,0" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Row="2" Content="가이드 및 튜토리얼 시작하기" 
                            Width="260" Height="45"
                            Background="#2196F3" Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E9ECEF" Margin="30,0,30,15" CornerRadius="0,0,10,10">
            <DockPanel Margin="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14" Foreground="#95A5A6"/>
                    <TextBlock Text="v1.0.0 | Developer: DH BIM Team" Margin="8,0,0,0" FontSize="11" Foreground="#7F8C8D"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#27AE60" Margin="0,0,8,0"/>
                    <TextBlock Text="Ready for Revit" FontSize="11" Foreground="#27AE60" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>